{
  "name": "tabletop",
  "version": "0.1.0",
  "description": "Tabletop RPG engine — Electron + React + Three.js + Supabase",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "dev:client2": "env -u ELECTRON_RUN_AS_NODE ELECTRON_RENDERER_URL=http://localhost:5173/ electron . --user-data-dir=.tmp/client2",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "db:login": "supabase login",
    "db:link": "supabase link --project-ref sovcqvbplrirxlzbuzte",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > src/models/database.types.ts"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "@react-three/rapier": "^1.5.0",
    "@supabase/supabase-js": "^2.45.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "electron-vite": "^2.3.0",
    "supabase": "^1.207.9",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "supabase"
    ]
  }
}
